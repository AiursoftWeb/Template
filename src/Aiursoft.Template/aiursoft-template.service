[Unit]
Description=Aiursoft Template Web Application
After=network.target

[Service]
WorkingDirectory=/usr/share/aiursoft-template
ExecStart=/usr/bin/dotnet /usr/share/aiursoft-template/Aiursoft.Template.dll --urls http://*:5000
Restart=always
RestartSec=10
KillSignal=SIGINT
SyslogIdentifier=aiursoft-template
User=www-data
Environment=ASPNETCORE_ENVIRONMENT=Production

[Install]
WantedBy=multi-user.target
